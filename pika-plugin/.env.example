# Cerebra neuro-eval plugin — copy to .env and fill in.
# Both values are printed by the Colab notebook (colab/cerebra_tribev2_server.ipynb)
# when you launch the scoring server.

# Public URL of the running TRIBE v2 scoring server (cloudflared / ngrok tunnel).
NEURO_API_URL=https://your-tunnel.trycloudflare.com

# Shared secret the server enforces on /score (x-api-key header). Optional, but a
# tunnel is public — set it. Leave blank only if the server has no NEURO_API_KEY.
NEURO_API_KEY=

# --- server side only (set these in the Colab / host, not the Pika client) ---
# HF_TOKEN=hf_...            # Hugging Face read token (TRIBE v2's gated language path)
# TRIBEV2_CACHE_DIR=./.cache # where weights + the brain atlas are cached
# TRIBEV2_TEXT_MODE=off      # off | auto | required
# TRIBEV2_MODALITIES=video   # video (universal T4 default) | video,audio
